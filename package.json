    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "wxt": "^0.20.25"
  },
  "dependencies": {
    "lucide-svelte": "^1.0.1",
    "zod": "^4.3.6"
